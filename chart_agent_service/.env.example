# ═══ Ollama ═══
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ═══ OpenAI (선택) ═══
OPENAI_API_KEY=

# ═══ 텔레그램 ═══
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ═══ 서비스 ═══
API_HOST=0.0.0.0
API_PORT=8100

# ═══ 스케줄러 ═══
SCAN_INTERVAL_MINUTES=30

# ═══ 관심 종목 ═══
WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA

# ═══ 알림 임계값 ═══
BUY_THRESHOLD=5.0
SELL_THRESHOLD=-5.0
MIN_CONFIDENCE=5.0
