# API 키 설정 (.env 파일로 복사하여 사용)
# cp .env.example .env

# OpenAI (GPT-4o 종합 분석 리포트용) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Google Gemini (대안 LLM) - https://aistudio.google.com/apikey
GOOGLE_API_KEY=xxxxx

# FRED (거시경제 데이터) - https://fred.stlouisfed.org/docs/api/api_key.html (무료)
FRED_API_KEY=xxxxx

# FMP (선택사항 - 추가 재무 데이터) - https://financialmodelingprep.com/
FMP_API_KEY=xxxxx

# Ollama (로컬/원격 LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# 텔레그램 (리포트 전송 / 봇 모드)
# 봇 생성: @BotFather → /newbot → 토큰 복사
# Chat ID 확인: python main.py --get-chat-id (봇에 아무 메시지 전송 후 실행)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=123456789
