# ═══════════════════════════════════════════════════════════════════
# Stock AI Analysis System - 통합 환경 설정 (single source of truth)
# ═══════════════════════════════════════════════════════════════════
# 사용법: cp .env.example .env
# 이 파일 하나로 stock_analyzer/ 와 chart_agent_service/ 양쪽이 동작합니다.

# ─── 필수: LLM 설정 ───────────────────────────────────────────────
# Ollama (로컬 LLM - 필수). 설치: ollama pull qwen3:14b-q4_K_M (~9GB)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b-q4_K_M

# ─── 선택: 외부 LLM API (없으면 Ollama만 사용) ────────────────────
# OpenAI - 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini - 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── 선택: 외부 데이터 API ────────────────────────────────────────
# FRED (거시 경제 - 무료) - 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# FMP (추가 재무 데이터 - 선택)
FMP_API_KEY=

# DART (한국 공시 - 무료) - 발급: https://opendart.fss.or.kr/
DART_API_KEY=

# ─── 선택: 텔레그램 알림 ──────────────────────────────────────────
# 봇 생성: @BotFather → /newbot → 토큰 복사
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 서비스 설정 ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8100
AGENT_API_HOST=localhost
AGENT_API_PORT=8100

# ─── 스케줄러 ─────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30

# ─── 스캔 병렬 처리 ────────────────────────────────────────────────
# 동시에 분석할 종목 수. Ollama OLLAMA_NUM_PARALLEL과 같은 값 권장.
# RTX 5070(12GB VRAM) + qwen3:14b(~9GB): 병렬 2 가능 (여유 3GB)
# Mac Studio M1 Max(32GB): 병렬 3 가능
# GPU 메모리 부족 시 1로 설정 (순차 실행)
SCAN_PARALLEL_WORKERS=3

# Ollama 동시 처리 수 (SCAN_PARALLEL_WORKERS와 맞춰야 병렬 효과 발휘)
# ollama serve 실행 전: export OLLAMA_NUM_PARALLEL=3
OLLAMA_NUM_PARALLEL=3

# ─── 관심 종목 (선택, watchlist.txt가 우선) ──────────────────────
WATCHLIST=

# ─── 알림 임계값 ──────────────────────────────────────────────────
BUY_THRESHOLD=5.0
SELL_THRESHOLD=-5.0
MIN_CONFIDENCE=5.0

# ─── 투자 스타일: scalping | swing | longterm ────────────────────
TRADING_STYLE=swing

# ─── 리스크 관리 ──────────────────────────────────────────────────
ACCOUNT_SIZE=100000
RISK_PER_TRADE_PCT=1.0
MAX_POSITION_PCT=20.0
TAKE_PROFIT_RR_RATIO=2.0

# ─── 듀얼 노드 LLM (선택, Mac Studio 원격 추론 시) ─────────────
# Tailscale MagicDNS 호스트네임 권장 (IP 변경에 강함)
# 미설정 시 자동으로 RTX 5070 단독 모드로 폴백
MAC_STUDIO_IP=hsptest-macstudio
MAC_STUDIO_URL=http://hsptest-macstudio:8080

# ─── Agent API 위치 (선택) ─────────────────────────────────────────
# 미설정 시 AGENT_API_HOST:AGENT_API_PORT 로 자동 합성
# 다른 머신에서 chart_agent_service 가 돌면 직접 가리킴 (예: Tailscale 호스트)
# AGENT_API_URL=http://localhost:8100

# ─── Multi-Agent / LLM Provider 설정 ──────────────────────────────
# DEFAULT_LLM_PROVIDER: ollama | gemini | openai (multi_agent.py 기본값)
DEFAULT_LLM_PROVIDER=ollama
# 8개 에이전트 동시 처리 워커 수 (Mac Studio + RTX 5070 양쪽 분산이라 4 권장)
# 2 면 직렬 가까워 180초 타임아웃 위험. 4 = 각 노드 동시 2개씩 진행.
MULTI_AGENT_MAX_WORKERS=4
# 멀티에이전트 전체 타임아웃 (초). 워커가 모자라면 늘려야.
MULTI_AGENT_TIMEOUT=300

# ─── Phase 2: 주문 실행 (기본은 paper) ─────────────────────────
# TRADING_MODE: paper | dry_run | approval | live
TRADING_MODE=paper
# BROKER_NAME: alpaca | kis (LIVE 모드에서만 사용, Phase 2.2+)
BROKER_NAME=
# 승인 후 실제 실행 모드 (APPROVAL 모드에서 승인 시 사용)
APPROVAL_EXEC_MODE=paper
# 일일 주문 한도
DAILY_ORDER_LIMIT_USD=1000
DAILY_ORDER_LIMIT_KRW=1000000
# 단일 주문 한도
SINGLE_ORDER_LIMIT_USD=200
SINGLE_ORDER_LIMIT_KRW=200000
# 승인 TTL (분) - 이 시간 초과 시 자동 만료
APPROVAL_TTL_MINUTES=30
# 장 시간 강제 (true 시 장외 주문 차단)
ENFORCE_MARKET_HOURS=false

# Phase 2 거래비용 (Sprint 1에서 적용됨)
TRADING_COMMISSION_PCT_KR=0.015
TRADING_COMMISSION_PCT_US=0.0
TRADING_SLIPPAGE_PCT=0.05
TRADING_SELL_TAX_PCT_KR=0.18

# 무위험 수익률 (Sharpe ratio 계산용)
ANNUAL_RISK_FREE_RATE=0.0

# ─── Phase 2.2: Alpaca (미국 증권사, 무료) ───────────────────
# 발급: https://alpaca.markets → Paper Trading 계좌 자동 생성
# Paper (테스트): https://paper-api.alpaca.markets
# Live (실제):    https://api.alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
# 데이터 feed: iex (free) | sip (paid)
ALPACA_DATA_FEED=iex

# 실시간 데이터 소스: yfinance(기본) | alpaca | polygon | kis
DATA_SOURCE=yfinance

# Phase 2.3+ (계획)
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=
# KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Phase 2.4 실시간 데이터 (선택)
# POLYGON_API_KEY=

# ─── GlobalKillSwitch 임계값 (Step 1) ─────────────────────────────────
# 일일 손실 알림 임계값 (%)
DAILY_LOSS_LIMIT_ALERT_PCT=2.0
# 일일 손실 강제 정지 임계값 (%)
DAILY_LOSS_LIMIT_HARD_PCT=3.0
# 주간 드로우다운 강제 정지 임계값 (%)
WEEKLY_DRAWDOWN_LIMIT_PCT=5.0
# 고점 대비 드로우다운 강제 정지 임계값 (%)
TRAILING_PEAK_DD_PCT=10.0
# 연속 손실 횟수 강제 정지 임계값
CONSECUTIVE_LOSS_COUNT=5
# VIX 절대 임계값 (이상 시 정지)
VIX_CAP=30.0
# VIX 단기 스파이크 임계값 (%)
VIX_SPIKE_PCT=20.0
# 데이터 최대 허용 경과 시간 (시간)
DATA_STALENESS_HALT_HOURS=6.0
# 정지 후 재개까지 대기 시간 (시간)
COOL_DOWN_HOURS=24
